{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "smart-blocks/education-item",
	"title": "Education Item",
	"category": "smart-blocks",
	"icon": "welcome-learn-more",
	"description": "A single education entry: degree, institution, year, optional grade.",
	"parent": [ "smart-blocks/education" ],
	"textdomain": "sachins-blocks",
	"supports": { "html": false, "reusable": false },
	"attributes": {
		"degree":      { "type": "string", "default": "" },
		"institution": { "type": "string", "default": "" },
		"years":       { "type": "string", "default": "" },
		"detail":      { "type": "string", "default": "" }
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        [ "smart-blocks-shared", "file:./style-index.css" ]
}
