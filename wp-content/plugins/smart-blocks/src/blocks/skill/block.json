{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "smart-blocks/skill",
	"title": "Skill",
	"category": "smart-blocks",
	"icon": "chart-line",
	"description": "A single skill tile with icon and name.",
	"parent": [ "smart-blocks/skills-showcase" ],
	"textdomain": "sachins-blocks",
	"supports": { "html": false, "reusable": false },
	"attributes": {
		"icon": { "type": "string", "default": "" },
		"name": { "type": "string", "default": "" },
		"meta": { "type": "string", "default": "" }
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        [ "smart-blocks-shared", "file:./style-index.css" ]
}
