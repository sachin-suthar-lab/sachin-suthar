{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "smart-blocks/timeline-item",
	"title": "Timeline Item",
	"category": "smart-blocks",
	"icon": "clock",
	"description": "Single career milestone. Used inside Experience Timeline.",
	"parent": [ "smart-blocks/experience-timeline" ],
	"textdomain": "smart-blocks",
	"supports": { "html": false, "reusable": false },
	"attributes": {
		"period": { "type": "string", "default": "" },
		"role":   { "type": "string", "default": "" },
		"org":    { "type": "string", "default": "" },
		"desc":   { "type": "string", "default": "" },
		"tags":   { "type": "array",  "default": [] }
	},
	"editorScript": "file:./index.js",
	"editorStyle":  "file:./index.css",
	"style":        [ "smart-blocks-shared", "file:./style-index.css" ],
	"render":       "file:./render.php"
}
