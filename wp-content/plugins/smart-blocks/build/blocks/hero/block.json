{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smart-blocks/hero",
  "title": "Hero",
  "category": "smart-blocks",
  "icon": "format-status",
  "description": "Two-column hero with badge, headline, lede, dual CTAs, portrait image, and metric cards.",
  "keywords": [
    "hero",
    "headline",
    "intro"
  ],
  "textdomain": "smart-blocks",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "anchor": true,
    "reusable": true
  },
  "attributes": {
    "badge": {
      "type": "string",
      "default": "Senior WordPress Developer · 7+ years"
    },
    "badgeDot": {
      "type": "boolean",
      "default": true
    },
    "headline": {
      "type": "string",
      "default": "WordPress engineering, built for"
    },
    "highlight": {
      "type": "string",
      "default": "long-term performance."
    },
    "lede": {
      "type": "string",
      "default": "I'm Sachin Suthar — a Senior WordPress Developer from Ahmedabad with 7+ years of hands-on experience across 70+ projects. I build custom themes, plugins, ACF and Gutenberg blocks, and performance-tuned WooCommerce stores for agencies, startups, and enterprise clients."
    },
    "ctaText": {
      "type": "string",
      "default": "Start a project"
    },
    "ctaUrl": {
      "type": "string",
      "default": "#contact"
    },
    "ctaSecondaryText": {
      "type": "string",
      "default": "View selected work"
    },
    "ctaSecondaryUrl": {
      "type": "string",
      "default": "#work"
    },
    "imageId": {
      "type": "number",
      "default": 0
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "metrics": {
      "type": "array",
      "default": [
        {
          "value": "7+",
          "label": "Years of WordPress engineering"
        },
        {
          "value": "70+",
          "label": "Projects shipped end-to-end"
        },
        {
          "value": "50+",
          "label": "Custom themes & plugins built"
        },
        {
          "value": "30–50%",
          "label": "Median performance gains"
        }
      ]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": [
    "smart-blocks-shared",
    "file:./style-index.css"
  ],
  "viewScript": "smart-blocks-reveal",
  "render": "file:./render.php"
}