{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smart-blocks/cta-section",
  "title": "CTA Section",
  "category": "smart-blocks",
  "icon": "megaphone",
  "description": "Bold call-to-action band with dual buttons.",
  "keywords": [
    "cta",
    "call to action"
  ],
  "textdomain": "smart-blocks",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "anchor": true,
    "reusable": true
  },
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Like what you see? Let's connect."
    },
    "dek": {
      "type": "string",
      "default": "Always happy to talk WordPress, swap notes on Gutenberg and performance, or just say hello."
    },
    "primaryText": {
      "type": "string",
      "default": "Say hello"
    },
    "primaryUrl": {
      "type": "string",
      "default": "#contact"
    },
    "secondaryText": {
      "type": "string",
      "default": "View GitHub"
    },
    "secondaryUrl": {
      "type": "string",
      "default": "https://github.com/sachin5713/"
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": [
    "smart-blocks-shared",
    "file:./style-index.css"
  ],
  "viewScript": "smart-blocks-reveal"
}