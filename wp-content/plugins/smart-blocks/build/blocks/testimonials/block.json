{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smart-blocks/testimonials",
  "title": "Testimonials",
  "category": "smart-blocks",
  "icon": "format-quote",
  "description": "Section heading + grid of editable Testimonial cards.",
  "keywords": [
    "testimonial",
    "quotes",
    "social proof"
  ],
  "textdomain": "smart-blocks",
  "supports": {
    "align": [
      "full"
    ],
    "html": false,
    "anchor": true,
    "reusable": true
  },
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Testimonials"
    },
    "heading": {
      "type": "string",
      "default": "What collaborators say."
    },
    "dek": {
      "type": "string",
      "default": "Feedback from the people I have shipped with — founders, engineering leaders, and product teams."
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": [
    "smart-blocks-shared",
    "file:./style-index.css"
  ],
  "viewScript": "smart-blocks-carousel"
}