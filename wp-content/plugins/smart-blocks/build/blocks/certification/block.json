{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smart-blocks/certification",
  "title": "Certification",
  "category": "smart-blocks",
  "icon": "awards",
  "description": "A single certification card. Used inside Certifications.",
  "parent": [
    "smart-blocks/certifications"
  ],
  "textdomain": "smart-blocks",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "issuer": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": [
    "smart-blocks-shared",
    "file:./style-index.css"
  ],
  "render": "file:./render.php"
}