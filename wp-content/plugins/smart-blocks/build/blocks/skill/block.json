{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "smart-blocks/skill",
  "title": "Skill",
  "category": "smart-blocks",
  "icon": "chart-line",
  "description": "A single skill with proficiency bar. Used inside Skills Showcase.",
  "parent": [
    "smart-blocks/skills-showcase"
  ],
  "textdomain": "smart-blocks",
  "supports": {
    "html": false,
    "reusable": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "default": ""
    },
    "proficiency": {
      "type": "number",
      "default": 80
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": [
    "smart-blocks-shared",
    "file:./style-index.css"
  ]
}