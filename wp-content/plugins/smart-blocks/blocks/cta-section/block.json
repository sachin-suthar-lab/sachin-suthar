{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "smart-blocks/cta-section",
	"title": "CTA Section",
	"category": "smart-blocks",
	"icon": "megaphone",
	"description": "Bold call-to-action band with dual buttons.",
	"keywords": ["cta", "call to action", "banner"],
	"textdomain": "smart-blocks",
	"supports": { "align": ["full"], "html": false, "anchor": true },
	"attributes": {
		"headingOverride": { "type": "string", "default": "" },
		"eyebrowOverride": { "type": "string", "default": "" }
	},
	"editorScript": "smart-blocks-editor",
	"editorStyle":  "smart-blocks-editor",
	"style":        "smart-blocks-frontend",
	"viewScript":   "smart-blocks-reveal",
	"render":       "file:./render.php"
}
