{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "smart-blocks/hero",
	"title": "Hero",
	"category": "smart-blocks",
	"icon": "format-status",
	"description": "Bold hero with badge, headline, dual CTAs, and key metrics.",
	"keywords": ["hero", "intro", "headline", "landing"],
	"textdomain": "smart-blocks",
	"supports": {
		"align": ["full"],
		"html": false,
		"customClassName": true,
		"anchor": true
	},
	"attributes": {
		"headingOverride": { "type": "string", "default": "" },
		"eyebrowOverride": { "type": "string", "default": "" }
	},
	"editorScript": "smart-blocks-editor",
	"editorStyle":  "smart-blocks-editor",
	"style":        "smart-blocks-frontend",
	"viewScript":   "smart-blocks-reveal",
	"render":       "file:./render.php"
}
